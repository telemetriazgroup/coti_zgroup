# ─── DATABASE ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zgroup_cotizaciones
DB_USER=zgroup_user
DB_PASSWORD=change_this_password

# ─── AUTH ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── SERVER ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── COOKIES ────────────────────────────────────────────
COOKIE_SECURE=false
# Set to true in production (requires HTTPS)

# ─── ADMIN INICIAL (solo para seed) ─────────────────────
ADMIN_EMAIL=admin@zgroup.pe
ADMIN_PASSWORD=ZGroup2025!

# ─── S3 / MINIO (Sprint 5) ──────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=zgroup-plans
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ─── REDIS (Sprint 5-6) ─────────────────────────────────
REDIS_URL=redis://localhost:6379
