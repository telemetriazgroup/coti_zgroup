# Copiar a .env y ajustar valores.
#
# Docker Compose: sin .env, postgres y app usan DB_PASSWORD por defecto
# `zgroup_dev_password`. Para pruebas desde el host contra ese Postgres,
# usa el mismo DB_PASSWORD aquí, DB_HOST=localhost y DB_PORT acorde al
# mapeo host (por defecto 5433: ver POSTGRES_HOST_PORT en docker-compose.yml).
#
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zgroup_cotizaciones
DB_USER=zgroup_user
DB_PASSWORD=cambiar

# JWT (generar secretos largos en producción, p.ej. openssl rand -hex 32)
JWT_ACCESS_SECRET=cambiar_access_secret_minimo_32_caracteres
JWT_REFRESH_SECRET=cambiar_refresh_secret_minimo_32_caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Origen del front (CORS + cookies). En Docker, debe coincidir con la URL del navegador
# (p. ej. si usas APP_HOST_PORT=3001 en compose: FRONTEND_URL=http://localhost:3001).
FRONTEND_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# Cookie refresh: true en HTTPS producción
COOKIE_SECURE=false

# Seed opcional (sobrescribe admin por defecto)
# ADMIN_EMAIL=admin@zgroup.pe
# ADMIN_PASSWORD=ZGroup2025!
