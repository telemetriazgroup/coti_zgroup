# Copiar a .env y ajustar valores.
#
# Docker Compose: sin .env, postgres y app usan DB_PASSWORD por defecto
# `zgroup_dev_password`. Para pruebas desde el host contra ese Postgres,
# usa el mismo DB_PASSWORD aquí, DB_HOST=localhost y DB_PORT acorde al
# mapeo host (por defecto 5433: ver POSTGRES_HOST_PORT en docker-compose.yml).
#
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zgroup_cotizaciones
DB_USER=zgroup_user
DB_PASSWORD=cambiar

# JWT (generar secretos largos en producción, p.ej. openssl rand -hex 32)
JWT_ACCESS_SECRET=cambiar_access_secret_minimo_32_caracteres
JWT_REFRESH_SECRET=cambiar_refresh_secret_minimo_32_caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Origen del front (CORS + cookies). En Docker, debe coincidir con la URL del navegador
# (p. ej. si usas APP_HOST_PORT=3001 en compose: FRONTEND_URL=http://localhost:3001).
# Acceso por IP pública (HTTP): FRONTEND_URL=http://TU_IP:3000 y RELAX_HELMET_HTTP=1
FRONTEND_URL=http://localhost:3000
# Orígenes extra CORS (coma), opcional
# ALLOWED_ORIGINS=http://10.0.0.5:3000
# Sin COOP/COEP de Helmet (menos avisos en consola en HTTP sobre IP; con HTTPS puedes omitir)
# RELAX_HELMET_HTTP=1
# Detrás de nginx/traefik con TLS
# TRUST_PROXY=1
# Subruta pública (Apache): sin barra final. Vacío = raíz (IP:3000).
# PUBLIC_BASE_PATH=/coti_zgroup
# Build Vite (barra final): debe coincidir con PUBLIC_BASE_PATH
# VITE_BASE_PATH=/coti_zgroup/
PORT=3000
NODE_ENV=development

# Redis (opcional): caché del catálogo TTL 24h; si está definido, export PDF usa cola BullMQ (worker en server).
# Sin REDIS_URL, el export PDF corre en el mismo proceso (setImmediate).
# Docker Compose puede definir REDIS_URL en el servicio app.
# REDIS_URL=redis://localhost:6379

# PDF: con Redis, BullMQ procesa el job en un Worker. Si falla la cola o Chromium, pon PDF_USE_QUEUE=0
# para generar el PDF en el mismo proceso (sin cola).
# PDF_USE_QUEUE=0

# PDF (Puppeteer): Docker/Alpine usa /usr/lib/chromium/chromium; en Debian/Ubuntu suele ser /usr/bin/chromium.
# PUPPETEER_EXECUTABLE_PATH=/usr/lib/chromium/chromium

# Cookie refresh: true en HTTPS producción (p. ej. detrás de Apache SSL)
COOKIE_SECURE=false

# Login: límite de intentos por IP (ventana en ms). Subir max si muchos usuarios comparten NAT.
# LOGIN_RATE_LIMIT_MAX=5
# LOGIN_RATE_LIMIT_WINDOW_MS=900000

# MinIO / S3 (planos técnicos). En Docker, S3_ENDPOINT es interno; el navegador usa S3_PUBLIC_ENDPOINT (puerto = MINIO_API_HOST_PORT).
# S3_ENDPOINT=http://minio:9000
# S3_PUBLIC_ENDPOINT=http://localhost:9010
# MINIO_API_HOST_PORT=9010
# MINIO_CONSOLE_HOST_PORT=9011
# S3_BUCKET=zgroup-plans
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1

# Seed opcional (sobrescribe admin por defecto)
# ADMIN_EMAIL=admin@zgroup.pe
# ADMIN_PASSWORD=ZGroup2025!
